{
  "name": "@rx-angular/template",
  "version": "21.2.0",
  "description": "**Fully** Reactive Component Template Rendering in Angular. @rx-angular/template aims to be a reflection of Angular's built in renderings just reactive.",
  "publishConfig": {
    "access": "public"
  },
  "author": "Michael Hladky <michael.hladky@push-based.io>",
  "homepage": "https://rx-angular.io/",
  "keywords": [
    "angular",
    "rxjs",
    "performance",
    "rendering",
    "template",
    "lazy templates",
    "memoized views",
    "scheduling",
    "coalescing",
    "concurrent rendering"
  ],
  "contributors": [
    {
      "name": "Michael Hladky",
      "email": "michael.hladky@push-based.io"
    },
    {
      "name": "Julian Jandl",
      "email": "julian@jandl.wien"
    },
    {
      "name": "Kirill Karnaukhov",
      "email": "karnaukhov.kh@gmail.com"
    },
    {
      "name": "Edouard Bozon",
      "email": "bozonedouard@gmail.com"
    },
    {
      "name": "Enea Jahollari",
      "email": "jahollarienea14@gmail.com"
    }
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/rx-angular/rx-angular.git"
  },
  "peerDependencies": {
    "@angular/core": "^21.0.0",
    "@rx-angular/cdk": "21.1.0",
    "rxjs": "^6.5.3 || ^7.4.0"
  },
  "dependencies": {
    "ng-morph": "^4.0.3",
    "tslib": "^2.4.1"
  },
  "schematics": "./schematics/collection.json",
  "ng-add": {
    "save": "dependencies"
  },
  "ng-update": {
    "migrations": "./schematics/migration.json"
  },
  "module": "fesm2022/template.mjs",
  "typings": "types/template.d.ts",
  "exports": {
    "./package.json": {
      "default": "./package.json"
    },
    ".": {
      "types": "./types/template.d.ts",
      "default": "./fesm2022/template.mjs"
    },
    "./experimental/viewport-prio": {
      "types": "./types/template-experimental-viewport-prio.d.ts",
      "default": "./fesm2022/template-experimental-viewport-prio.mjs"
    },
    "./for": {
      "types": "./types/template-for.d.ts",
      "default": "./fesm2022/template-for.mjs"
    },
    "./if": {
      "types": "./types/template-if.d.ts",
      "default": "./fesm2022/template-if.mjs"
    },
    "./let": {
      "types": "./types/template-let.d.ts",
      "default": "./fesm2022/template-let.mjs"
    },
    "./push": {
      "types": "./types/template-push.d.ts",
      "default": "./fesm2022/template-push.mjs"
    },
    "./unpatch": {
      "types": "./types/template-unpatch.d.ts",
      "default": "./fesm2022/template-unpatch.mjs"
    },
    "./virtual-scrolling": {
      "types": "./types/template-virtual-scrolling.d.ts",
      "default": "./fesm2022/template-virtual-scrolling.mjs"
    },
    "./virtual-view": {
      "types": "./types/template-virtual-view.d.ts",
      "default": "./fesm2022/template-virtual-view.mjs"
    }
  },
  "sideEffects": false
}